APP_NAME=CholoJai
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null

# MySQL is the production target (see docker-compose.yml).
# For zero-config dev, switch DB_CONNECTION to sqlite and point DATABASE at a file.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cholo_jai
DB_USERNAME=cholo
DB_PASSWORD=cholo

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

SANCTUM_STATEFUL_DOMAINS=
FRONTEND_ORIGIN=http://localhost:3000

# Admin user created by AdminUserSeeder
ADMIN_EMAIL=admin@cholojai.test
ADMIN_PASSWORD=password

# Seed the 18 demo events from frontend_rebuild/lib/fallback-data.ts
SEED_DEMO_EVENTS=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@cholojai.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
