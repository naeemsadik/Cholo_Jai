# Files excluded from the Docker build context (sent to the daemon when
# `docker compose build` runs). Smaller context = faster builds.

# Git + cache
.git
.gitignore
.github
.gitattributes

# Local artifacts
.idea
.vscode
*.log
.phpunit.result.cache

# Frontend (we only deploy the backend)
../frontend_rebuild
../frontend

# Docker / deploy / docs not needed at runtime
docker-compose.yml
.dockerignore
Dockerfile
README.md
*.md
DEPLOY.md

# Local dev databases / uploads
database/database.sqlite
storage/app/public/uploads/

# Tests (phpunit not needed at runtime)
tests
phpunit.xml

# Production assets that we don't ship in the backend image
public/build/
public/hot

# IDE / editor swap files
*.swp
*.swo
*~
.DS_Store