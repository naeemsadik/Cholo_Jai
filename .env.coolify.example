# Copy this to `.env` next to your docker-compose.yml on the VPS (Coolify
# will mount it for you). Fill in every value before `docker compose up -d`.
#
# Coolify note: in the Coolify UI, set these as Service → Environment
# Variables instead of using a .env file if you prefer.

# ── MySQL (used by the `db` service) ───────────────────────────────────
MYSQL_ROOT_PASSWORD=replace-me-strong-root-pw
MYSQL_DATABASE=cholo_jai
MYSQL_USER=cholo
MYSQL_PASSWORD=replace-me-strong-app-pw

# ── Laravel core ────────────────────────────────────────────────────────
APP_ENV=production
APP_KEY=                                         # run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.cholojai.bd
LOG_LEVEL=info

# ── Frontend / CORS ─────────────────────────────────────────────────────
# The Next.js frontend that calls this API. Used for CORS + redirects.
FRONTEND_ORIGIN=https://cholojai.bd
FRONTEND_URL=https://cholojai.bd
PUBLIC_API_URL=https://api.cholojai.bd
SERVICE_FQDN_BACKEND=api.cholojai.bd
SERVICE_URL_BACKEND=https://api.cholojai.bd

# ── Admin user (created by AdminUserSeeder on first migrate --seed) ────
ADMIN_EMAIL=admin@cholojai.bd
ADMIN_PASSWORD=replace-me-strong-admin-pw

# ── Optional seeders ────────────────────────────────────────────────────
# Set true only on the very first deploy if you want 18 demo events.
SEED_DEMO_EVENTS=false
RUN_SEED=false